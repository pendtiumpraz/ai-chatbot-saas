# Privasimu Docker Environment Variables
# Copy this file to .env before running docker-compose up -d

# Project Name (used as Docker prefix)
COMPOSE_PROJECT_NAME=privasimu

# ==========================================
# 1. Database Configuration (MySQL)
# ==========================================
DB_DATABASE=privasimu
DB_USERNAME=privasimu_user
DB_PASSWORD=secret_db_password_here
DB_ROOT_PASSWORD=secret_root_password_here

# ==========================================
# 2. Redis Configuration
# ==========================================
# Default is fine for Docker internal networking
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# 3. Application Settings
# ==========================================
APP_NAME=Privasimu
APP_ENV=production
APP_KEY= # Generate via `docker-compose exec backend php artisan key:generate --show`
APP_DEBUG=false
APP_URL=http://localhost:8000 # Update with your domain if using reverse proxy

# ==========================================
# 4. Auth & JWT
# ==========================================
JWT_SECRET= # Generate via `docker-compose exec backend php artisan jwt:secret --show`
JWT_ALGO=RS256

# ==========================================
# 5. Frontend Configuration
# ==========================================
# The API URL accessed by the frontend browser
NEXT_PUBLIC_API_URL=/api

# ==========================================
# 6. Advanced Features (Optional)
# ==========================================
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ENABLE_AI_FEATURES=true
